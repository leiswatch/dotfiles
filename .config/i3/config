client.focused           $blue     $blue      $base     $blue     $blue
client.focused_inactive  $overlay1 $overlay1  $base     $overlay1 $overlay1
client.unfocused         $blue     $base      $text     $overlay1 $overlay1
client.urgent            $sapphire $base      $sapphire $overlay0 $sapphire
client.placeholder       $overlay0 $base      $text     $overlay0 $overlay0
client.background        $base

default_border pixel 2
for_window [class=".*"] border pixel 2 move position center
for_window [window_role="Popup"] border pixel 0
for_window [window_role="pop-up"] border pixel 0
gaps inner 10

for_window [class="Pavucontrol"] floating enable
for_window [class="Blueman-manager"] floating enable
for_window [title="Picture-in-Picture"] floating enable sticky enable
for_window [title="Picture in picture"] floating enable sticky enable
for_window [class="firefox" window_role="Popup"] border pixel 0
for_window [class="Google-chrome" window_role="pop-up"] border pixel 2 floating enable
for_window [class="Brave-browser" window_role="pop-up"] border pixel 2 floating enable
for_window [class="MEGAsync"] border pixel 0 floating enable
for_window [class="Qalculate-gtk"] floating enable

