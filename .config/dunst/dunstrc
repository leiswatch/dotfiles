[global]
    gaps = true
    gap_size = 5
    monitor = 0
    width=(200, 600)
    height=(100, 500)
    origin = top-right
    class       = Dunst
    alignment   = center
    frame_color = "#fab387"
    frame_width = 2
    font        = JetBrains Mono 13
    offset      = 15x50
    min_icon_size = 0
    max_icon_size = 24
    show_indicators = yes
    show_age_threshold = 60
    icon_position = left
    icon_path = /usr/share/icons/Papirus-Dark/32x32/status/:/usr/share/icons/Papirus-Dark/32x32/devices/:/usr/share/icons/Papirus-Dark/32x32/apps/:/usr/share/icons/Papirus-Dark/32x32/actions/:/usr/share/icons/Papirus-Dark/32x32/categories/:/usr/share/icons/Papirus-Dark/32x32/emblems/:/usr/share/icons/Papirus-Dark/32x32/emotes/:/usr/share/icons/Papirus-Dark/32x32/mimetypes
    notification_limit = 0
    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    indicate_hidden = yes
    separator_color= frame
    corner_radius = 0
    highlight = "#fab387"

[urgency_low]
    background = "#1E1E2E"
    foreground = "#cdd6f4"
    timeout = 5

[urgency_normal]
    background = "#1E1E2E"
    foreground = "#cdd6f4"
    timeout = 5

[urgency_critical]
    background  = "#1E1E2E"
    foreground  = "#cdd6f4"
    timeout = 5

[fullscreen_delay_everything]
    fullscreen = delay

[fullscreen_show_critical]
    msg_urgency = critical
    fullscreen = show
