[global]
    gap_size = 5
    monitor = 0
    width = (200, 400)
    height = 300
    origin = top-right
    class       = Dunst
    alignment   = center
    frame_color = "#fab387"
    frame_width = 2
    font        = Fira Sans 12
    offset      = 10x40
    min_icon_size = 0
    max_icon_size = 24
    show_indicators = yes
    show_age_threshold = -1
    icon_position = left
    icon_theme = Papirus
    enable_recursive_icon_lookup = true
    notification_limit = 5
    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    indicate_hidden = yes
    separator_color= frame
    corner_radius = 0
    highlight = "#fab387"
    hide_duplicate_count = false
    sticky_history = false

[urgency_low]
    background = "#1E1E2E"
    foreground = "#cdd6f4"
    timeout = 6

[urgency_normal]
    background = "#1E1E2E"
    foreground = "#cdd6f4"
    timeout = 6

[urgency_critical]
    background  = "#1E1E2E"
    foreground  = "#cdd6f4"
    timeout = 6

[fullscreen_delay_everything]
    fullscreen = delay

[fullscreen_show_critical]
    msg_urgency = critical
    fullscreen = show
