[global]
    monitor = 0
    width=(200, 600)
    height=(0, 250)
    origin = top-right
    class       = Dunst
    alignment   = center
    frame_color = "#DDB6F2"
    frame_width = 2
    font        = Jetbrains Mono 13
    offset      = 5x40
    min_icon_size = 0
    max_icon_size = 32
    show_indicators = yes
    show_age_threshold = 60
    icon_position = left
    icon_theme = Papirus-Dark
    enable_recursive_icon_lookup = true
    notification_limit = 0
    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    indicate_hidden = yes
    separator_color= frame
    corner_radius = 4

[urgency_low]
    background = "#1E1D2F"
    foreground = "#D9E0EE"
    timeout = 5

[urgency_normal]
    background = "#1E1D2F"
    foreground = "#D9E0EE"
    timeout = 5

[urgency_critical]
    background  = "#1E1D2F"
    foreground  = "#F28FAD"
    timeout = 5
